model_list:
  - model_name: shkandal-article-card
    litellm_params:
      model: openai/MamayLM-Gemma-3-27B-IT-v2.0
      api_base: https://api.lapathoniia.top/v1
      api_key: os.environ/LAPATONIA_API_KEY
    rpm: 60
  - model_name: shkandal-case-resolution
    litellm_params:
      model: openai/MamayLM-Gemma-3-27B-IT-v2.0
      api_base: https://api.lapathoniia.top/v1
      api_key: os.environ/LAPATONIA_API_KEY
    rpm: 30
  - model_name: shkandal-entity-resolution
    litellm_params:
      model: openai/MamayLM-Gemma-3-27B-IT-v2.0
      api_base: https://api.lapathoniia.top/v1
      api_key: os.environ/LAPATONIA_API_KEY
    rpm: 60
  - model_name: shkandal-event-resolution
    litellm_params:
      model: openai/MamayLM-Gemma-3-27B-IT-v2.0
      api_base: https://api.lapathoniia.top/v1
      api_key: os.environ/LAPATONIA_API_KEY
    rpm: 60
  - model_name: shkandal-case-copy-update
    litellm_params:
      model: openai/MamayLM-Gemma-3-27B-IT-v2.0
      api_base: https://api.lapathoniia.top/v1
      api_key: os.environ/LAPATONIA_API_KEY
    rpm: 30
  - model_name: shkandal-repair
    litellm_params:
      model: openai/MamayLM-Gemma-3-27B-IT-v2.0
      api_base: https://api.lapathoniia.top/v1
      api_key: os.environ/LAPATONIA_API_KEY
    rpm: 60
  - model_name: shkandal-bedrock-fallback
    litellm_params:
      model: bedrock/converse/google.gemma-3-27b-it
      aws_region_name: os.environ/AWS_REGION_NAME

litellm_settings:
  drop_params: true

router_settings:
  num_retries: 0
  fallbacks:
    - shkandal-article-card:
        - shkandal-bedrock-fallback
    - shkandal-case-resolution:
        - shkandal-bedrock-fallback
    - shkandal-entity-resolution:
        - shkandal-bedrock-fallback
    - shkandal-event-resolution:
        - shkandal-bedrock-fallback
    - shkandal-case-copy-update:
        - shkandal-bedrock-fallback
    - shkandal-repair:
        - shkandal-bedrock-fallback
