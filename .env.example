BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
QDRANT_PORT=6333
LITELLM_PROXY_PORT=4000

POSTGRES_USER=shkandal
POSTGRES_PASSWORD=shkandal_dev_password
POSTGRES_DB=shkandal
POSTGRES_HOST=postgres
POSTGRES_DATABASE_URL=postgresql://shkandal:shkandal_dev_password@postgres:5432/shkandal

QDRANT_URL=http://qdrant:6333
LLM_API_BASE=http://llm-proxy:4000/v1
LLM_API_KEY=replace-me
LLM_ARTICLE_CARD_MODEL=shkandal-article-card
LLM_CASE_RESOLUTION_MODEL=shkandal-case-resolution
LLM_ENTITY_RESOLUTION_MODEL=shkandal-entity-resolution
LLM_EVENT_RESOLUTION_MODEL=shkandal-event-resolution
LLM_REPAIR_MODEL=shkandal-repair

# Provider keys are consumed by the LiteLLM proxy. Set real values in .env.
OPENAI_API_KEY=replace-me

# Copy this file to .env for local Docker Compose runs.
# Keep real secrets out of git.
