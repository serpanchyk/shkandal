#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
project_dir="$(cd -- "${script_dir}/.." && pwd)"

cd "${project_dir}"

if [[ ! -f .env ]]; then
    echo "missing ${project_dir}/.env" >&2
    exit 66
fi

set -a
# shellcheck disable=SC1091
source .env
set +a

if [[ -z "${POSTGRES_DATABASE_URL:-}" ]]; then
    echo "POSTGRES_DATABASE_URL is not configured in ${project_dir}/.env" >&2
    exit 78
fi

postgres_port="${POSTGRES_PORT:-5432}"
export POSTGRES_DATABASE_URL="${POSTGRES_DATABASE_URL/@postgres:5432/@localhost:${postgres_port}}"

uv run alembic -c packages/database/alembic.ini upgrade head
