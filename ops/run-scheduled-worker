#!/usr/bin/env bash
set -euo pipefail

worker="${1:-}"
case "${worker}" in
    worker-ingestion|worker-ml) ;;
    *)
        echo "usage: $0 {worker-ingestion|worker-ml}" >&2
        exit 64
        ;;
esac

container_name="shkandal-scheduled-${worker}"

cleanup() {
    docker rm -f "${container_name}" >/dev/null 2>&1 || true
}

handle_signal() {
    cleanup
    exit 143
}

if docker container inspect "${container_name}" >/dev/null 2>&1; then
    if [[ "$(docker container inspect --format '{{.State.Running}}' "${container_name}")" == "true" ]]; then
        echo "scheduled worker already running: ${container_name}" >&2
        exit 75
    fi
    cleanup
fi

trap cleanup EXIT
trap handle_signal INT TERM

docker compose --profile jobs run --name "${container_name}" "${worker}"
